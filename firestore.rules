rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && callerRole() == "admin";
    }

    function isSelf(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // users
    match /users/{uid} {
      allow read: if isAdmin()
                  || isSelf(uid)
                  || (isAuth() && callerRole() == "projectLead");
      allow create: if isAdmin()
                    || (isSelf(uid) && request.resource.data.role in ["admin", "employee", "projectLead"]);
      allow update: if isAdmin()
                    || (isSelf(uid) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // communities
    match /communities/{communityID} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      match /feed/{messageID} {
        allow read, create: if isAuth();
        allow delete: if isAdmin();
      }

      match /tasks/{taskID} {
        allow read: if isAuth();
        allow create, delete: if isAuth() && (isAdmin() || callerRole() == "projectLead");
        allow update: if isAuth() && (
                         isAdmin()
                         || callerRole() == "projectLead"
                         || (callerRole() == "employee" && resource.data.assignedToID == request.auth.uid)
                       );
      }

      // Project documents + embedded chunks
      match /projectDocs/{docID} {
        allow read: if isAuth();
        allow create, update, delete: if isAuth()
                                      && (isAdmin() || callerRole() == "projectLead");
        match /chunks/{chunkID} {
          allow read: if isAuth();
          allow write: if isAuth()
                       && (isAdmin() || callerRole() == "projectLead");
        }
      }
    }

    // announcements
    match /announcements/{announcementID} {
      allow create: if isAuth() && (isAdmin() || callerRole() == "projectLead");
      allow read: if isAdmin()
                  || (isAuth() && (
                        !("targetUID" in resource.data)
                        || resource.data.targetUID == request.auth.uid
                     ));
      allow update, delete: if isAdmin();
    }

    // issues
    match /issues/{issueID} {
      allow create: if true;
      allow read: if isAdmin() || isAuth();   // employees need to look up by Case ID
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // checkIns — employees write/read their own; admin reads all
    match /checkIns/{checkInID} {
      allow create: if isAuth();
      allow read: if isAuth() && (
                      isAdmin()
                      || resource.data.uid == request.auth.uid
                    );
      allow update, delete: if isAdmin();
    }

    // employeeOfMonth — all authenticated users can read (shown on all dashboards)
    //                    only admin can write/delete
    match /employeeOfMonth/{docID} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // salary statements stored under each user document
    match /users/{uid}/salaryStatements/{statID} {
      allow read: if isAdmin() || isSelf(uid);
      allow write: if isAdmin();
    }

    // deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
